{
  "name": "multer-module",
  "version": "2.0.0",
  "description": "Template Multer File Upload",
  "homepage": "https://github.com/DeividRobertoGA/multer-module#readme",
  "bugs": {
    "url": "https://github.com/DeividRobertoGA/multer-module/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeividRobertoGA/multer-module.git"
  },
  "license": "UNLICENSED",
  "author": "Deivid Roberto",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "nodemon": "nodemon app.js",
    "migrate:make": "npx knex migrate:make --stub ./src/database/template/migration.template.js",
    "migrate:latest": "npx knex migrate:latest",
    "migrate:rollback": "npx knex migrate:rollback",
    "seed:make": "npx knex seed:make --stub ./src/database/template/seed.template.js",
    "seed:run": "npx knex seed:run",
    "knex:init": "npm run migrate:latest && npm run seed:run"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "colors": "^1.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.3.0",
    "multer": "^2.2.0",
    "mysql2": "^3.22.5",
    "nodemon": "^3.1.14"
  }
}
